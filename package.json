{
  "name": "doc-gen",
  "version": "1.0.0",
  "description": "aura",
  "main": "electron/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "electron:dev": "electron electron/main.js",
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,magenta \"npm --prefix frontend run dev\" \"wait-on http://localhost:5173 && npm run electron:dev\"",
    "build:frontend": "npm --prefix frontend run build",
    "dist": "npm run build:frontend && electron-builder --win"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doc-Gen-org/Doc-Gen.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Doc-Gen-org/Doc-Gen/issues"
  },
  "homepage": "https://github.com/Doc-Gen-org/Doc-Gen#readme",
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "react-router-dom": "^7.18.1"
  },
  "build": {
    "appId": "com.acatechnologies.docgen",
    "productName": "DocGen",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "resources/backend", "to": "backend" },
      { "from": "resources/ollama", "to": "ollama" },
      { "from": "resources/tesseract", "to": "tesseract" },
      { "from": "resources/poppler", "to": "poppler" },
      { "from": "resources/gtk3-runtime", "to": "gtk3-runtime" }
    ],
    "win": {
      "target": "dir"
    }
  }
}